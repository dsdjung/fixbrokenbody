---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Home">
  <div class="container">
    <section class="hero">
      <h1>Fix Broken Body</h1>
      <p class="hero-subtitle">
        Documenting my journey of healing, recovery, and building a stronger body.
      </p>
      <div class="hero-cta">
        <a href={`${base}journey/`} class="btn btn-primary">Read My Story</a>
        <a href={`${base}diary/`} class="btn btn-outline">View Diary</a>
      </div>
    </section>

    <section class="home-grid">
      <a href={`${base}journey/`} class="card home-card">
        <div class="home-card-icon">&#x1F3AF;</div>
        <h2>My Journey</h2>
        <p>Why I started, where I am now, and where I'm headed.</p>
      </a>

      <a href={`${base}facts/`} class="card home-card">
        <div class="home-card-icon">&#x1F4D6;</div>
        <h2>Facts</h2>
        <p>Research, insights, and knowledge I've gathered about body recovery.</p>
      </a>

      <a href={`${base}diary/`} class="card home-card">
        <div class="home-card-icon">&#x1F4DD;</div>
        <h2>Diary</h2>
        <p>Day-by-day entries documenting progress, setbacks, and lessons.</p>
      </a>

      <a href={`${base}media/`} class="card home-card">
        <div class="home-card-icon">&#x1F3AC;</div>
        <h2>Media</h2>
        <p>Videos and photos from my journey — progress, exercises, and more.</p>
      </a>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 4rem 0 3rem;
  }

  .hero h1 {
    font-family: var(--font-serif);
    font-size: 3.5rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 550px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s;
    border: 2px solid transparent;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-dark);
    color: white;
  }

  .btn-outline {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .btn-outline:hover {
    background: var(--color-primary);
    color: white;
  }

  .home-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
    padding-bottom: 2rem;
  }

  .home-card {
    text-align: center;
    text-decoration: none;
    color: var(--color-text);
    display: block;
  }

  .home-card:hover {
    color: var(--color-text);
  }

  .home-card-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .home-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .home-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .hero {
      padding: 2rem 0;
    }
  }
</style>
