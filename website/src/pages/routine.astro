---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Daily Routine">
  <div class="container">
    <div class="page-header">
      <h1>Daily Routine</h1>
      <p>My structured daily plan for recovery and building a stronger body.</p>
    </div>

    <div class="routine">
      <section class="time-block card">
        <div class="time-badge">Morning</div>
        <h2>Wake Up & Prep</h2>
        <ul class="checklist">
          <li><label><input type="checkbox" /> Wake up at ___</label></li>
          <li><label><input type="checkbox" /> Drink a glass of water</label></li>
          <li><label><input type="checkbox" /> 5 min stretching / mobility</label></li>
          <li><label><input type="checkbox" /> Breakfast</label></li>
        </ul>
        <details class="why-section">
          <summary>Why I do this</summary>
          <div class="why-content">
            <p>Add your reasoning here. For example: why you wake up at a specific time, why stretching in bed first thing matters, why hydration comes before food, etc.</p>
          </div>
        </details>
      </section>

      <section class="time-block card">
        <div class="time-badge">Mid-Morning</div>
        <h2>Movement & Exercise</h2>
        <ul class="checklist">
          <li><label><input type="checkbox" /> Warm up (5 min)</label></li>
          <li><label><input type="checkbox" /> Exercise routine (30–45 min)</label></li>
          <li><label><input type="checkbox" /> Cool down & stretch (10 min)</label></li>
          <li><label><input type="checkbox" /> Post-workout nutrition</label></li>
        </ul>
        <details class="why-section">
          <summary>Why I do this</summary>
          <div class="why-content">
            <p>Add your reasoning here. For example: why mid-morning is the best time for you, why you chose this exercise structure, what you're building toward, etc.</p>
          </div>
        </details>
      </section>

      <section class="time-block card">
        <div class="time-badge">Afternoon</div>
        <h2>Recovery & Nutrition</h2>
        <ul class="checklist">
          <li><label><input type="checkbox" /> Healthy lunch</label></li>
          <li><label><input type="checkbox" /> Walk / light movement (15–20 min)</label></li>
          <li><label><input type="checkbox" /> Foam rolling or massage</label></li>
          <li><label><input type="checkbox" /> Hydration check</label></li>
        </ul>
        <details class="why-section">
          <summary>Why I do this</summary>
          <div class="why-content">
            <p>Add your reasoning here. For example: why a post-lunch walk helps with glucose, why foam rolling aids recovery, etc.</p>
          </div>
        </details>
      </section>

      <section class="time-block card">
        <div class="time-badge">Evening</div>
        <h2>Wind Down</h2>
        <ul class="checklist">
          <li><label><input type="checkbox" /> Healthy dinner</label></li>
          <li><label><input type="checkbox" /> Evening stretch / yoga (10–15 min)</label></li>
          <li><label><input type="checkbox" /> Journal / diary entry</label></li>
          <li><label><input type="checkbox" /> Prepare for tomorrow</label></li>
        </ul>
        <details class="why-section">
          <summary>Why I do this</summary>
          <div class="why-content">
            <p>Add your reasoning here. For example: why evening stretching activates the parasympathetic nervous system, why journaling keeps you accountable, etc.</p>
          </div>
        </details>
      </section>

      <section class="time-block card">
        <div class="time-badge">Night</div>
        <h2>Sleep</h2>
        <ul class="checklist">
          <li><label><input type="checkbox" /> No screens 30 min before bed</label></li>
          <li><label><input type="checkbox" /> Lights out by ___</label></li>
        </ul>
        <details class="why-section">
          <summary>Why I do this</summary>
          <div class="why-content">
            <p>Add your reasoning here. For example: why you target a specific number of hours, why screens before bed disrupt melatonin, why sleep is Step Zero for fixing a broken body, etc.</p>
          </div>
        </details>
      </section>

      <div class="reset-bar">
        <button id="reset-btn" class="btn-reset">Reset All Checkboxes</button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const STORAGE_KEY = 'fbb-routine-checks';

  function loadState() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (!saved) return;
      const state = JSON.parse(saved);
      const boxes = document.querySelectorAll<HTMLInputElement>('.checklist input[type="checkbox"]');
      boxes.forEach((box, i) => {
        if (state[i]) box.checked = true;
      });
    } catch {}
  }

  function saveState() {
    const boxes = document.querySelectorAll<HTMLInputElement>('.checklist input[type="checkbox"]');
    const state = Array.from(boxes).map((b) => b.checked);
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  }

  loadState();

  document.querySelectorAll('.checklist input[type="checkbox"]').forEach((box) => {
    box.addEventListener('change', saveState);
  });

  document.getElementById('reset-btn')?.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.checklist input[type="checkbox"]').forEach((box) => {
      box.checked = false;
    });
    localStorage.removeItem(STORAGE_KEY);
  });
</script>

<style>
  .routine {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .time-block {
    position: relative;
    padding-top: 2.25rem;
  }

  .time-badge {
    position: absolute;
    top: -0.75rem;
    left: 1.5rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .time-block h2 {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .checklist li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .checklist li:last-child {
    border-bottom: none;
  }

  .checklist label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    font-size: 1rem;
    color: var(--color-text);
    transition: color 0.2s;
  }

  .checklist input[type='checkbox'] {
    width: 20px;
    height: 20px;
    accent-color: var(--color-primary);
    cursor: pointer;
    flex-shrink: 0;
  }

  .checklist input[type='checkbox']:checked + span,
  .checklist label:has(input:checked) {
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .why-section {
    margin-top: 1rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
  }

  .why-section summary {
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: 0.25rem 0;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .why-section summary::-webkit-details-marker {
    display: none;
  }

  .why-section summary::before {
    content: '▸';
    display: inline-block;
    transition: transform 0.2s;
    font-size: 0.8rem;
  }

  .why-section[open] summary::before {
    transform: rotate(90deg);
  }

  .why-section summary:hover {
    color: var(--color-primary-dark);
  }

  .why-content {
    padding: 0.75rem 0 0.25rem 1.25rem;
    font-size: 0.925rem;
    color: var(--color-text-muted);
    line-height: 1.65;
    font-family: var(--font-serif);
  }

  .why-content p {
    margin: 0 0 0.5rem;
  }

  .why-content p:last-child {
    margin-bottom: 0;
  }

  .reset-bar {
    text-align: center;
    padding: 1rem 0;
  }

  .btn-reset {
    background: none;
    border: 2px solid var(--color-border);
    color: var(--color-text-muted);
    padding: 0.5rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-reset:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }
</style>
