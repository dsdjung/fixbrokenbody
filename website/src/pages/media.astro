---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Media">
  <div class="container">
    <div class="page-header">
      <h1>Media</h1>
      <p>Videos and photos documenting my journey.</p>
    </div>

    <section class="media-section">
      <h2>Videos</h2>
      <p class="section-hint">Add your YouTube video embeds below. Replace the sample with your actual video URLs.</p>
      <div class="video-grid">
        <!--
          To add a YouTube video, copy this block and replace the VIDEO_ID:
          <div class="video-card card">
            <div class="video-embed">
              <iframe
                src="https://www.youtube.com/embed/VIDEO_ID"
                title="Video title"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            </div>
            <h3>Video Title</h3>
            <p>Brief description of the video.</p>
          </div>
        -->
        <div class="video-card card">
          <div class="video-embed video-placeholder">
            <p>Your first video here</p>
          </div>
          <h3>Sample Video</h3>
          <p>Replace this with your YouTube embed. See the HTML comments for the template.</p>
        </div>
      </div>
    </section>

    <section class="media-section">
      <h2>Instagram</h2>
      <p class="section-hint">Follow the journey on Instagram for daily updates, photos, and progress.</p>
      <a href="https://www.instagram.com/fixbrokenbody/" target="_blank" rel="noopener" class="card ig-profile-card">
        <div class="ig-profile-header">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="ig-icon"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <div>
            <h3>@fixbrokenbody</h3>
            <span class="link-arrow">Follow on Instagram &rarr;</span>
          </div>
        </div>
      </a>

      <div class="ig-embeds">
        <!--
          To embed an Instagram post:
          1. Go to the post on Instagram
          2. Click the three dots (...) > Embed
          3. Copy the embed code and paste it here
          4. Or simply use the blockquote format below with the post URL:

          <blockquote class="instagram-media" data-instgrm-permalink="https://www.instagram.com/p/POST_ID/" data-instgrm-version="14">
          </blockquote>
        -->
      </div>
    </section>

    <script async src="//www.instagram.com/embed.js"></script>
  </div>
</BaseLayout>

<style>
  .media-section {
    max-width: 900px;
    margin: 0 auto 3rem;
  }

  .media-section h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .section-hint {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .video-card h3 {
    margin: 1rem 0 0.25rem;
    font-size: 1.1rem;
  }

  .video-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .video-embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 8px;
    background: var(--color-bg-alt);
  }

  .video-embed iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .video-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .video-placeholder p {
    position: absolute;
    color: var(--color-text-muted);
    font-size: 1rem;
  }

  .ig-profile-card {
    display: block;
    color: var(--color-text);
    text-decoration: none;
    max-width: 400px;
    margin-bottom: 2rem;
  }

  .ig-profile-card:hover {
    color: var(--color-text);
  }

  .ig-profile-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .ig-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .ig-profile-header h3 {
    font-size: 1.2rem;
    margin-bottom: 0.15rem;
  }

  .ig-embeds {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  .link-arrow {
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
