---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('diary');
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const base = import.meta.env.BASE_URL;
const { entry } = Astro.props;
const { Content } = await render(entry);

const routine = entry.data.routine;
const blocks = routine
  ? [
      { key: 'morning', label: '6 AM', icon: '🌅', data: routine.morning },
      { key: 'exercise', label: '7 AM', icon: '💪', data: routine.exercise },
      { key: 'meal1', label: '10 AM', icon: '🍳', data: routine.meal1 },
      { key: 'meal2', label: '5:30', icon: '🍽️', data: routine.meal2 },
      { key: 'sleep', label: '10 PM', icon: '😴', data: routine.sleep },
    ]
  : null;

const completed = blocks ? blocks.filter((b) => b.data?.done).length : 0;
const total = blocks ? blocks.length : 0;
const sleepLog = entry.data.sleep_log;
---

<BaseLayout title={entry.data.title}>
  <div class="container">
    <article class="diary-entry">
      <a href={`${base}diary/`} class="back-link">&larr; Back to Diary</a>
      <header>
        <time>{entry.data.date}</time>
        <h1>{entry.data.title}</h1>
        {
          entry.data.tags && (
            <div class="tags">
              {entry.data.tags.map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }
      </header>

      {
        blocks && (
          <div class="scorecard">
            <div class="scorecard-header">
              <span class="scorecard-title">Routine Scorecard</span>
              <span class="scorecard-score">
                {completed}/{total}
              </span>
            </div>
            <div class="scorecard-bar">
              <div class="scorecard-fill" style={`width: ${(completed / total) * 100}%`} />
            </div>
            <div class="scorecard-blocks">
              {blocks.map((block) => (
                <div class={`scorecard-block ${block.data?.done ? 'done' : 'missed'}`}>
                  <span class="block-icon">{block.icon}</span>
                  <span class="block-label">{block.label}</span>
                  <span class="block-status">{block.data?.done ? '✓' : '✗'}</span>
                  {block.data?.note && <span class="block-note">{block.data.note}</span>}
                </div>
              ))}
            </div>
          </div>
        )
      }

      {sleepLog && (sleepLog.bedtime || sleepLog.waketime || sleepLog.hours) && (
        <div class="sleep-log">
          <span class="sleep-log-icon">🛏️</span>
          <div class="sleep-log-details">
            {sleepLog.bedtime && sleepLog.waketime && (
              <span class="sleep-times">{sleepLog.bedtime} → {sleepLog.waketime}</span>
            )}
            {sleepLog.hours && (
              <span class="sleep-hours">{sleepLog.hours}h sleep</span>
            )}
          </div>
        </div>
      )}

      <div class="prose">
        <Content />
      </div>

      {
        entry.data.instagram && entry.data.instagram.length > 0 && (
          <div class="diary-instagram">
            {entry.data.instagram.map((url: string) => (
              <blockquote
                class="instagram-media"
                data-instgrm-permalink={url}
                data-instgrm-version="14"
              />
            ))}
          </div>
        )
      }
    </article>
  </div>
  {entry.data.instagram && entry.data.instagram.length > 0 && (
    <script async src="//www.instagram.com/embed.js"></script>
  )}
</BaseLayout>

<style>
  .diary-entry {
    max-width: 750px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  time {
    font-size: 0.9rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin: 0.5rem 0 0.75rem;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-weight: 500;
  }

  /* Scorecard */
  .scorecard {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 2rem;
    box-shadow: var(--shadow);
  }

  .scorecard-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .scorecard-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .scorecard-score {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-primary);
  }

  .scorecard-bar {
    height: 6px;
    background: var(--color-bg-alt);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .scorecard-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent));
    border-radius: 3px;
    transition: width 0.3s;
  }

  .scorecard-blocks {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.5rem;
  }

  .scorecard-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    padding: 0.5rem 0.25rem;
    border-radius: 8px;
    text-align: center;
  }

  .scorecard-block.done {
    background: rgba(76, 175, 80, 0.08);
  }

  .scorecard-block.missed {
    background: rgba(244, 67, 54, 0.06);
  }

  .block-icon {
    font-size: 1.25rem;
  }

  .block-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
  }

  .block-status {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .done .block-status {
    color: #4caf50;
  }

  .missed .block-status {
    color: #e57373;
  }

  .block-note {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.3;
  }

  /* Sleep Log */
  .sleep-log {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
  }

  .sleep-log-icon {
    font-size: 1.5rem;
  }

  .sleep-log-details {
    display: flex;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .sleep-times {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .sleep-hours {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    background: rgba(76, 175, 80, 0.1);
    padding: 0.15rem 0.5rem;
    border-radius: 12px;
  }

  .diary-instagram {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .scorecard-blocks {
      grid-template-columns: repeat(5, 1fr);
      gap: 0.35rem;
    }

    .block-label {
      font-size: 0.6rem;
    }

    .block-icon {
      font-size: 1rem;
    }
  }
</style>
