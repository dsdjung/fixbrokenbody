---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('diary')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getScore(routine: any) {
  if (!routine) return null;
  const blocks = [routine.morning, routine.exercise, routine.afternoon, routine.evening, routine.sleep];
  const total = blocks.length;
  const done = blocks.filter((b: any) => b?.done).length;
  return { done, total };
}
---

<BaseLayout title="Diary">
  <div class="container">
    <div class="page-header">
      <h1>Diary</h1>
      <p>Day-by-day documentation of my recovery journey.</p>
    </div>

    <div class="diary-list">
      {
        entries.map((entry) => {
          const score = getScore(entry.data.routine);
          return (
            <a href={`${base}diary/${entry.id}/`} class="card diary-card">
              <div class="diary-card-main">
                <time class="diary-date">{entry.data.date}</time>
                <h2>{entry.data.title}</h2>
                {entry.data.summary && <p class="diary-summary">{entry.data.summary}</p>}
                {entry.data.tags && (
                  <div class="diary-tags">
                    {entry.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              {score && (
                <div class="mini-score">
                  <div class="mini-score-ring">
                    <svg viewBox="0 0 36 36">
                      <path
                        class="ring-bg"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                      />
                      <path
                        class="ring-fill"
                        stroke-dasharray={`${(score.done / score.total) * 100}, 100`}
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                      />
                    </svg>
                    <span class="ring-text">{score.done}/{score.total}</span>
                  </div>
                </div>
              )}
            </a>
          );
        })
      }
    </div>

    {
      entries.length === 0 && (
        <p class="empty-state">
          No diary entries yet. Add markdown files to <code>src/content/diary/</code>.
        </p>
      )
    }
  </div>
</BaseLayout>

<style>
  .diary-list {
    max-width: 750px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .diary-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .diary-card:hover {
    color: var(--color-text);
  }

  .diary-card-main {
    flex: 1;
  }

  .diary-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diary-card h2 {
    font-size: 1.2rem;
    margin: 0.25rem 0 0.5rem;
  }

  .diary-summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .diary-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-weight: 500;
  }

  /* Mini score ring */
  .mini-score {
    flex-shrink: 0;
  }

  .mini-score-ring {
    position: relative;
    width: 52px;
    height: 52px;
  }

  .mini-score-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-bg {
    fill: none;
    stroke: var(--color-bg-alt);
    stroke-width: 3;
  }

  .ring-fill {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 3;
    stroke-linecap: round;
  }

  .ring-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .empty-state code {
    background: var(--color-bg-alt);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }
</style>
