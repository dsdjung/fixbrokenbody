---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('diary')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Diary">
  <div class="container">
    <div class="page-header">
      <h1>Diary</h1>
      <p>Day-by-day documentation of my recovery journey.</p>
    </div>

    <div class="diary-list">
      {
        entries.map((entry) => (
          <a href={`${base}diary/${entry.id}/`} class="card diary-card">
            <time class="diary-date">{entry.data.date}</time>
            <h2>{entry.data.title}</h2>
            {entry.data.summary && <p class="diary-summary">{entry.data.summary}</p>}
            {entry.data.tags && (
              <div class="diary-tags">
                {entry.data.tags.map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))
      }
    </div>

    {
      entries.length === 0 && (
        <p class="empty-state">
          No diary entries yet. Add markdown files to <code>src/content/diary/</code>.
        </p>
      )
    }
  </div>
</BaseLayout>

<style>
  .diary-list {
    max-width: 750px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .diary-card {
    display: block;
    color: var(--color-text);
    text-decoration: none;
  }

  .diary-card:hover {
    color: var(--color-text);
  }

  .diary-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diary-card h2 {
    font-size: 1.2rem;
    margin: 0.25rem 0 0.5rem;
  }

  .diary-summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .diary-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-weight: 500;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .empty-state code {
    background: var(--color-bg-alt);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }
</style>
