---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const entries = (await getCollection('diary')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function getScore(routine: any) {
  if (!routine) return null;
  const blocks = [routine.morning, routine.exercise, routine.meal1, routine.meal2, routine.sleep];
  const total = blocks.length;
  const done = blocks.filter((b: any) => b?.done).length;
  return { done, total };
}
---

<BaseLayout title="Diary">
  <div class="container">
    <div class="page-header">
      <h1>Diary</h1>
      <p>Day-by-day documentation of my recovery journey.</p>
    </div>

    <div class="diary-list">
      {
        entries.map((entry) => {
          const score = getScore(entry.data.routine);
          return (
            <a href={`${base}diary/${entry.id}/`} class="card diary-card">
              <div class="diary-card-main">
                <time class="diary-date">{entry.data.date}</time>
                <h2>{entry.data.title}</h2>
                {entry.data.summary && <p class="diary-summary">{entry.data.summary}</p>}
                {entry.data.tags && (
                  <div class="diary-tags">
                    {entry.data.tags.map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
              {entry.data.sleep_log?.hours && (
                <div class="diary-sleep-badge" title={`${entry.data.sleep_log.hours}h sleep`}>
                  <span>😴</span>
                  <span>{entry.data.sleep_log.hours}h</span>
                </div>
              )}
              {entry.data.instagram && entry.data.instagram.length > 0 && (
                <div class="diary-ig-badge" title={`${entry.data.instagram.length} photo${entry.data.instagram.length > 1 ? 's' : ''}`}>
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <span>{entry.data.instagram.length}</span>
                </div>
              )}
              {score && (
                <div class="mini-score">
                  <div class="mini-score-ring">
                    <svg viewBox="0 0 36 36">
                      <path
                        class="ring-bg"
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                      />
                      <path
                        class="ring-fill"
                        stroke-dasharray={`${(score.done / score.total) * 100}, 100`}
                        d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"
                      />
                    </svg>
                    <span class="ring-text">{score.done}/{score.total}</span>
                  </div>
                </div>
              )}
            </a>
          );
        })
      }
    </div>

    {
      entries.length === 0 && (
        <p class="empty-state">
          No diary entries yet. Add markdown files to <code>src/content/diary/</code>.
        </p>
      )
    }
  </div>
</BaseLayout>

<style>
  .diary-list {
    max-width: 750px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .diary-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .diary-card:hover {
    color: var(--color-text);
  }

  .diary-card-main {
    flex: 1;
  }

  .diary-date {
    font-size: 0.85rem;
    color: var(--color-primary);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .diary-card h2 {
    font-size: 1.2rem;
    margin: 0.25rem 0 0.5rem;
  }

  .diary-summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .diary-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-weight: 500;
  }

  /* Sleep badge */
  .diary-sleep-badge {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }

  /* Instagram badge */
  .diary-ig-badge {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 600;
  }

  /* Mini score ring */
  .mini-score {
    flex-shrink: 0;
  }

  .mini-score-ring {
    position: relative;
    width: 52px;
    height: 52px;
  }

  .mini-score-ring svg {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
  }

  .ring-bg {
    fill: none;
    stroke: var(--color-bg-alt);
    stroke-width: 3;
  }

  .ring-fill {
    fill: none;
    stroke: var(--color-primary);
    stroke-width: 3;
    stroke-linecap: round;
  }

  .ring-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .empty-state code {
    background: var(--color-bg-alt);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }
</style>
