---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const facts = (await getCollection('facts')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Facts">
  <div class="container">
    <div class="page-header">
      <h1>Facts</h1>
      <p>Research, insights, and knowledge about fixing a broken body.</p>
    </div>

    <div class="facts-list">
      {
        facts.map((fact, index) => (
          <a href={`${base}facts/${fact.id}/`} class="card fact-card">
            <span class="fact-number">#{index + 1}</span>
            <div class="fact-body">
              <h2>{fact.data.title}</h2>
              {fact.data.summary && <p class="fact-summary">{fact.data.summary}</p>}
              <span class="fact-link">Read the research &rarr;</span>
            </div>
          </a>
        ))
      }
    </div>

    {
      facts.length === 0 && (
        <p class="empty-state">
          No facts added yet. Add markdown files to <code>src/content/facts/</code>.
        </p>
      )
    }
  </div>
</BaseLayout>

<style>
  .facts-list {
    max-width: 750px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .fact-card {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .fact-card:hover {
    color: var(--color-text);
  }

  .fact-number {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-primary-light);
    flex-shrink: 0;
    line-height: 1.3;
  }

  .fact-body {
    flex: 1;
  }

  .fact-card h2 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary-dark);
    line-height: 1.4;
  }

  .fact-summary {
    color: var(--color-text-muted);
    font-size: 0.925rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .fact-link {
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .fact-card:hover .fact-link {
    color: var(--color-primary-dark);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .empty-state code {
    background: var(--color-bg-alt);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }
</style>
