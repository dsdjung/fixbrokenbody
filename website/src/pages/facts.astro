---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

const facts = (await getCollection('facts')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);
---

<BaseLayout title="Facts">
  <div class="container">
    <div class="page-header">
      <h1>Facts</h1>
      <p>Research, insights, and knowledge about fixing a broken body.</p>
    </div>

    <div class="facts-list">
      {
        facts.map(async (fact) => {
          const { Content } = await render(fact);
          return (
            <article class="card fact-card">
              <h2>{fact.data.title}</h2>
              <div class="prose">
                <Content />
              </div>
            </article>
          );
        })
      }
    </div>

    {
      facts.length === 0 && (
        <p class="empty-state">No facts added yet. Add markdown files to <code>src/content/facts/</code>.</p>
      )
    }
  </div>
</BaseLayout>

<style>
  .facts-list {
    max-width: 750px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .fact-card h2 {
    font-size: 1.3rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary-dark);
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 1.1rem;
  }

  .empty-state code {
    background: var(--color-bg-alt);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }
</style>
